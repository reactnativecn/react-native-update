{
  "name": "e2etest",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "server": "bun scripts/local-e2e-server.ts",
    "prepare:e2e": "node scripts/run-prepare-local-update-artifacts.js",
    "test:e2e:ios": "E2E_PLATFORM=ios detox test --configuration ios.sim.release",
    "test:e2e:android": "E2E_PLATFORM=android detox test --configuration android.emu.release --headless --record-logs all",
    "test:e2e:harmony": "jest --config e2e/harmony.jest.config.js",
    "apk": "cd android && ./gradlew assembleRelease",
    "aab": "cd android && ./gradlew bundleRelease",
    "aa": "cd android && ./gradlew assembleRelease bundleRelease"
  },
  "dependencies": {
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-update": "^10.40.0-beta.2"
  },
  "devDependencies": {
    "@babel/core": "^7.27.3",
    "@babel/runtime": "^7.27.3",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "detox": "^20.51.4",
    "jest": "^29.6.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "trustedDependencies": [
    "detox",
    "dtrace-provider"
  ]
}
